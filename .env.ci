# Настройки для облачного запуска (GitHub Actions). БЕЗ секретов!
# Токен (TELEGRAM_TOKEN) и получатели (CHAT_IDS) задаются в секретах репозитория.

EXCHANGES=binance,bybit,bitget,gate,kucoin
SCAN_MODE=top
MAX_SYMBOLS=500
MIN_VOLUME_USDT=5000000
MIN_EXCHANGES=2
INTERVAL=1h
CHECK_INTERVAL_SECONDS=300
SIGNAL_THRESHOLD=69
COOLDOWN_MINUTES=15

REQUIRE_FUTURES=true
WHALES_AUTO=true
WHALES_TOP_N=30
WHALES_MIN_ACCOUNT=2000000

WEIGHT_TA=3.0
WEIGHT_MULTITF=2.5
WEIGHT_DERIVATIVES=2.5
WEIGHT_ORDERFLOW=2.0
WEIGHT_VOLUME_PROFILE=2.0
WEIGHT_LIQUIDATIONS=1.5
WEIGHT_LIQ_ZONES=1.5
WEIGHT_WHALES=2.0
WEIGHT_MARKETMAKERS=1.0
WEIGHT_REGIME=1.0

MM_AUTO=true
MM_TOP_N=20
MM_MIN_VOLUME=50000000
WEIGHT_NEWS=1.5
WEIGHT_TELEGRAM=1.5
WEIGHT_FEAR_GREED=1.0
WEIGHT_COINGECKO_FDV=1.0
WEIGHT_DEFILLAMA=1.0
WEIGHT_COINMARKETCAP=1.0

EMA_FAST=9
EMA_SLOW=21
EMA_TREND=50
RSI_PERIOD=14
RSI_LONG_MIN=50
RSI_LONG_MAX=72
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
ATR_PERIOD=14
STOP_ATR_MULT=3.0
TAKE_ATR_MULT=2.0
